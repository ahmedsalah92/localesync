{
	"compilerOptions": {
		"composite": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2020",
		"lib": ["ES2020"], // env-neutral: modern JS built-ins (Set/Map), NO DOM — common stays ambient-free
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"emitDeclarationOnly": true,
		"types": [],
		"outDir": "./node_modules/.tmp/tsc"
	},
	"include": ["**/*.ts"],
	// Test files import vitest, whose type graph assumes DOM/Node ambient globals — pulling them
	// into this env-neutral composite build would defeat the ambient-free guardrail. Vitest runs
	// them (npm test); the compile-time type-check files (no vitest import) stay in the build.
	"exclude": ["**/*.test.ts"]
}
