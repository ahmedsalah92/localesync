{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020"], // NO DOM — main thread has none
    "strict": true,
    "types": ["@figma/plugin-typings"],
    "emitDeclarationOnly": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "./node_modules/.tmp/tsc"
  },
  "include": ["**/*.ts"],
  // Same guardrail as src/common: vitest's type graph assumes Node/DOM ambients this main-thread
  // build must not see. Vitest still runs these (npm test); ESLint types them via projectService.
  "exclude": ["**/*.test.ts"],
  "references": [{ "path": "../common" }]
}
